# ====================================================================
#  Credenciales RAG  ->  copia este archivo a  .env  y rellena los valores
#  (este .env es solo para INDEXAR en local; en la nube se usan los secrets)
# ====================================================================

# --- Google Gemini (embeddings 2.0 + generacion) --------------------
# Crea la clave en https://aistudio.google.com/apikey
GOOGLE_API_KEY=tu_api_key_de_google_aistudio

# --- Pinecone (base de datos vectorial) -----------------------------
# Clave en https://app.pinecone.io  ->  API Keys
PINECONE_API_KEY=tu_api_key_de_pinecone
PINECONE_INDEX=palen-tour-rag
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# --- Supabase Storage (imagenes de las paginas fuente) --------------
# URL del proyecto (la misma que usa la web)
SUPABASE_URL=https://TU-PROYECTO.supabase.co
# CLAVE service_role (Settings -> API).  SOLO en local para indexar.
# NUNCA la subas al repo ni la pongas en React.
SUPABASE_SERVICE_KEY=tu_service_role_key
RAG_BUCKET=rag-media

# --- Modelos (no hace falta tocar) ----------------------------------
EMBED_MODEL=gemini-embedding-2
EMBED_DIM=1536
GEN_MODEL=gemini-2.5-flash

# --- Modo admin: muestra los controles de indexacion en la barra -----
# Ponlo a 1 SOLO en local. En produccion (publico) dejalo vacio o quitalo.
RAG_ADMIN=1
