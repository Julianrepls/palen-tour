# ====================================================================
#  Credenciales RAG  ->  copia este archivo a  .env  y rellena los valores
# ====================================================================

# --- Google Gemini (embeddings 2.0 + generacion) --------------------
# Crea la clave en https://aistudio.google.com/apikey
GOOGLE_API_KEY=tu_api_key_de_google_aistudio

# --- Pinecone (base de datos vectorial) -----------------------------
# Clave en https://app.pinecone.io  ->  API Keys
PINECONE_API_KEY=tu_api_key_de_pinecone

# Nombre del indice (se crea solo la primera vez si no existe)
PINECONE_INDEX=palen-tour-rag

# Region serverless de Pinecone (deja estos valores salvo que sepas otra cosa)
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# --- Modelos (no hace falta tocar) ----------------------------------
EMBED_MODEL=gemini-embedding-2
EMBED_DIM=1536
GEN_MODEL=gemini-2.5-flash
