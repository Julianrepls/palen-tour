# ====================================================================
#  Secrets de la app desplegada en Streamlit Community Cloud.
#  NO se commitea el archivo real: pega este contenido en
#  share.streamlit.io -> tu app -> Settings -> Secrets.
#
#  La app PUBLICA solo consulta Pinecone + Gemini y lee las imagenes
#  desde URLs publicas de Supabase. NO necesita la clave de Supabase
#  ni RAG_ADMIN (la indexacion se hace solo en local).
# ====================================================================

GOOGLE_API_KEY = "tu_api_key_de_google_aistudio"
PINECONE_API_KEY = "tu_api_key_de_pinecone"

# Opcionales (solo si cambiaste los valores por defecto):
# PINECONE_INDEX = "palen-tour-rag"
# PINECONE_CLOUD = "aws"
# PINECONE_REGION = "us-east-1"
# EMBED_MODEL = "gemini-embedding-2"
# EMBED_DIM = "1536"
